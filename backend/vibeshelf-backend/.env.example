# Example .env file for backend/vibeshelf-backend
# Copy this file to .env and fill in the real values. Do NOT commit .env to git.

# GROQ configuration
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: path to a file containing the key (useful for Docker secrets)
# GROQ_API_KEY_FILE=/run/secrets/GROQ_API_KEY
